    {
      "name": "00 Setup Times",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": ["{{base_url}}"],
          "path": ["auth", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const start = new Date(now.getTime() + 2 * 60 * 60 * 1000);",
              "const end = new Date(now.getTime() + 3 * 60 * 60 * 1000);",
              "const updStart = new Date(now.getTime() + 4 * 60 * 60 * 1000);",
              "const updEnd = new Date(now.getTime() + 5 * 60 * 60 * 1000);",
              "pm.collectionVariables.set('booking_start_time', start.toISOString());",
              "pm.collectionVariables.set('booking_end_time', end.toISOString());",
              "pm.collectionVariables.set('booking_update_start_time', updStart.toISOString());",
              "pm.collectionVariables.set('booking_update_end_time', updEnd.toISOString());",
              "pm.test('time variables prepared', function () { pm.expect(true).to.eql(true); });"
            ]
          }
        }
      ]
